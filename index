<style>
:root{--bg:#04050f;--surface:#0a0d1f;--card:#0f1428;--border:#1e2a5e;--accent:#3b82f6;--accent2:#06b6d4;--gold:#f59e0b;--text:#e2e8f0;--muted:#64748b;--green:#10b981;--red:#ef4444;}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;background-image:radial-gradient(1px 1px at 10% 20%,rgba(255,255,255,.5) 0%,transparent 100%),radial-gradient(1px 1px at 30% 60%,rgba(255,255,255,.3) 0%,transparent 100%),radial-gradient(1px 1px at 50% 10%,rgba(255,255,255,.4) 0%,transparent 100%),radial-gradient(1px 1px at 70% 80%,rgba(255,255,255,.5) 0%,transparent 100%),radial-gradient(1px 1px at 90% 40%,rgba(255,255,255,.3) 0%,transparent 100%),radial-gradient(1px 1px at 80% 15%,rgba(255,255,255,.5) 0%,transparent 100%),radial-gradient(600px 600px at 20% 50%,rgba(59,130,246,.05) 0%,transparent 70%),radial-gradient(600px 600px at 80% 20%,rgba(6,182,212,.05) 0%,transparent 70%);}
header{position:relative;z-index:10;text-align:center;padding:48px 24px 36px;border-bottom:1px solid var(--border);background:linear-gradient(180deg,rgba(59,130,246,.08) 0%,transparent 100%);}
.logo-rocket{font-size:48px;display:block;margin-bottom:12px;filter:drop-shadow(0 0 20px rgba(59,130,246,.8));animation:float 3s ease-in-out infinite;}
@keyframes float{0%,100%{transform:translateY(0);}50%{transform:translateY(-8px);}}
header h1{font-family:'Orbitron',monospace;font-weight:900;font-size:clamp(26px,5vw,50px);letter-spacing:.05em;background:linear-gradient(135deg,#fff 0%,var(--accent2) 50%,var(--accent) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:8px;}
.tagline{font-size:13px;color:var(--muted);letter-spacing:.15em;text-transform:uppercase;margin-bottom:16px;}
.badge{display:inline-flex;align-items:center;gap:6px;background:rgba(245,158,11,.12);border:1px solid rgba(245,158,11,.4);color:var(--gold);font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;padding:5px 14px;border-radius:20px;}
#syncStatus{font-size:11px;color:var(--muted);margin-top:12px;}
.sync-dot{display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--muted);margin-right:5px;vertical-align:middle;transition:background .3s;}
.sync-dot.ok{background:var(--green);}
.sync-dot.err{background:var(--red);}
.controls{position:relative;z-index:10;max-width:900px;margin:28px auto 0;padding:0 24px;display:flex;flex-wrap:wrap;gap:12px;align-items:center;justify-content:space-between;}
.search-wrap{position:relative;flex:1;min-width:220px;}
.search-wrap svg{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--muted);pointer-events:none;}
.search-wrap input{width:100%;background:var(--card);border:1px solid var(--border);border-radius:10px;color:var(--text);font-size:14px;padding:10px 14px 10px 40px;outline:none;transition:border .2s;}
.search-wrap input:focus{border-color:var(--accent);}
.search-wrap input::placeholder{color:var(--muted);}
.stat-pills{display:flex;gap:8px;flex-wrap:wrap;}
.pill{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:8px 14px;font-size:12px;color:var(--muted);white-space:nowrap;}
.pill span{font-family:'Orbitron',monospace;font-size:14px;font-weight:700;color:var(--text);margin-right:4px;}
.pill.green span{color:var(--green);}
.pill.red span{color:var(--red);}
.table-wrap{position:relative;z-index:10;max-width:900px;margin:24px auto 60px;padding:0 24px;}
table{width:100%;border-collapse:separate;border-spacing:0 4px;}
thead tr th{background:var(--surface);color:var(--muted);font-size:11px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;padding:12px 16px;text-align:left;border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
thead tr th:first-child{border-left:1px solid var(--border);border-radius:8px 0 0 8px;}
thead tr th:last-child{border-right:1px solid var(--border);border-radius:0 8px 8px 0;text-align:center;}
tbody tr{cursor:pointer;transition:transform .15s;}
tbody tr:hover{transform:translateX(3px);}
tbody tr:hover td{background:rgba(59,130,246,.08)!important;border-color:rgba(59,130,246,.4)!important;}
tbody tr td{background:var(--card);padding:12px 16px;font-size:13px;border-top:1px solid var(--border);border-bottom:1px solid var(--border);transition:background .15s,border .15s;vertical-align:middle;}
tbody tr td:first-child{border-left:1px solid var(--border);border-radius:8px 0 0 8px;}
tbody tr td:last-child{border-right:1px solid var(--border);border-radius:0 8px 8px 0;text-align:center;}
.num{font-family:'Orbitron',monospace;font-size:11px;color:var(--muted);min-width:48px;}
.code-cell{font-family:'Share Tech Mono',monospace;font-size:15px;color:var(--accent2);letter-spacing:.06em;}
.status-badge{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;padding:3px 10px;border-radius:20px;min-width:88px;justify-content:center;}
.status-badge.available{background:rgba(16,185,129,.12);border:1px solid rgba(16,185,129,.4);color:var(--green);}
.status-badge.used{background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.4);color:var(--red);}
.status-badge::before{content:'';width:6px;height:6px;border-radius:50%;background:currentColor;}
.qr-btn{background:rgba(59,130,246,.15);border:1px solid rgba(59,130,246,.4);color:var(--accent);font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;padding:5px 12px;border-radius:6px;cursor:pointer;transition:all .2s;}
.qr-btn:hover{background:rgba(59,130,246,.3);border-color:var(--accent);}
.modal-overlay{display:none;position:fixed;inset:0;z-index:100;background:rgba(4,5,15,.85);backdrop-filter:blur(8px);align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:40px 36px;max-width:380px;width:90%;text-align:center;position:relative;box-shadow:0 0 80px rgba(59,130,246,.2);animation:popIn .25s cubic-bezier(.34,1.56,.64,1);}
@keyframes popIn{from{opacity:0;transform:scale(.85);}to{opacity:1;transform:scale(1);}}
.modal-close{position:absolute;top:16px;right:16px;background:var(--surface);border:1px solid var(--border);color:var(--muted);width:32px;height:32px;border-radius:8px;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.modal-close:hover{color:var(--text);border-color:var(--accent);}
.modal h3{font-family:'Orbitron',monospace;font-size:11px;color:var(--muted);letter-spacing:.15em;text-transform:uppercase;margin-bottom:6px;}
.modal-code{font-family:'Share Tech Mono',monospace;font-size:18px;color:var(--accent2);letter-spacing:.08em;margin-bottom:24px;word-break:break-all;}
#qr-container{display:flex;justify-content:center;margin-bottom:24px;}
#qr-container>div{padding:12px;background:white;border-radius:12px;}
.modal-instruction{font-size:12px;color:var(--muted);line-height:1.6;margin-bottom:20px;}
.modal-instruction strong{color:var(--text);}
.redeem-btn{display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,var(--accent),var(--accent2));color:white;font-size:13px;font-weight:600;padding:11px 28px;border-radius:10px;text-decoration:none;transition:all .2s;margin-bottom:12px;width:100%;justify-content:center;}
.redeem-btn:hover{opacity:.9;transform:translateY(-1px);box-shadow:0 8px 24px rgba(59,130,246,.4);}
.mark-used-btn{width:100%;background:transparent;border:1px solid var(--border);color:var(--muted);font-size:12px;padding:9px;border-radius:10px;cursor:pointer;transition:all .2s;}
.mark-used-btn:hover{border-color:var(--red);color:var(--red);background:rgba(239,68,68,.08);}
.loading-row td{text-align:center;padding:40px;color:var(--muted);font-size:13px;}
.no-result{text-align:center;padding:60px 24px;color:var(--muted);display:none;}
.no-result .icon{font-size:40px;margin-bottom:12px;}
footer{position:relative;z-index:10;text-align:center;padding:24px;border-top:1px solid var(--border);color:var(--muted);font-size:12px;}
::-webkit-scrollbar{width:6px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}
@media(max-width:600px){.col-qr{display:none;}.code-cell{font-size:11px;letter-spacing:0;}}
</style>
</head>
<body>
<header>
  <span class="logo-rocket">🚀</span>
  <h1>ROCKET RUN</h1>
  <p class="tagline">Alpha Tester Access Portal</p>
  <span class="badge">⭐ Exclusive Alpha Testing Program</span>
  <div id="syncStatus"><span class="sync-dot" id="syncDot"></span><span id="syncText">Menghubungkan ke server...</span></div>
</header>

<div class="controls">
  <div class="search-wrap">
    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
    <input type="text" id="searchInput" placeholder="Cari nomor atau kode..." oninput="filterCodes()">
