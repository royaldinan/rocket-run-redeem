    <div class="pill green"><span id="availCount">—</span> Tersedia</div>
    <div class="pill red"><span id="usedCount">—</span> Terpakai</div>
  </div>
</div>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>No.</th>
        <th>Kode Akses</th>
        <th>Status</th>
