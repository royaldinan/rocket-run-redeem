    </tbody>
  </table>
  <div class="no-result" id="noResult">
    <div class="icon">🔍</div>
    <p>Kode tidak ditemukan</p>
  </div>
</div>

<div class="modal-overlay" id="modalOverlay" onclick="closeModal(event)">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">×</button>
    <h3>Kode Alpha Tester</h3>
    <div class="modal-code" id="modalCode"></div>
    <div id="qr-container"></div>
    <p class="modal-instruction">
      Scan QR code untuk langsung buka halaman redeem,<br>atau klik tombol di bawah.<br><br>
      <strong>Play Store → Foto Profil → Pembayaran & Langganan → Tukarkan Kode</strong>
    </p>
    <a id="redeemLink" href="#" target="_blank" class="redeem-btn">🎮 Redeem di Google Play Store</a>
    <button class="mark-used-btn" id="markUsedBtn" onclick="toggleUsed()">✓ Tandai Sudah Digunakan</button>
  </div>
</div>

<footer>Rocket Run Lite — Alpha Testing Program &nbsp;|&nbsp; Exhibition</footer>

