const REDEEM_BASE = 'https://play.google.com/redeem?code=';
const TABLE_NAME  = 'used_codes';

let sb = null;
let usedSet = new Set();
let activeIndex = null;
let qrInstance  = null;

async function init() {
  try {
    sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
    await loadFromSupabase();
    subscribeRealtime();
    setSyncStatus('ok', '🟢 Terhubung — sinkron real-time');
  } catch(e) {
    console.error(e);
    setSyncStatus('err', '🔴 Gagal konek — pakai localStorage');
    usedSet = new Set(JSON.parse(localStorage.getItem('usedCodes') || '[]'));
    renderTable();
    updateStats();
  }
}

async function loadFromSupabase() {
  const { data, error } = await sb.from(TABLE_NAME).select('code_index');
  if (error) throw error;
  usedSet = new Set((data || []).map(r => r.code_index));
  renderTable();
  updateStats();
}

function subscribeRealtime() {
  sb.channel('used_codes_changes')
    .on('postgres_changes', { event: '*', schema: 'public', table: TABLE_NAME }, () => {
      loadFromSupabase();
    })
    .subscribe();
}

function setSyncStatus(state, text) {
  document.getElementById('syncDot').className = 'sync-dot ' + state;
  document.getElementById('syncText').textContent = text;
}

async function toggleUsed() {
  if (activeIndex === null) return;
  const isUsed = usedSet.has(activeIndex);
  if (sb) {
    if (isUsed) {
      await sb.from(TABLE_NAME).delete().eq('code_index', activeIndex);
    } else {
      await sb.from(TABLE_NAME).insert({ code_index: activeIndex, code: CODES[activeIndex] });
    }
  } else {
    if (isUsed) usedSet.delete(activeIndex); else usedSet.add(activeIndex);
    localStorage.setItem('usedCodes', JSON.stringify([...usedSet]));
    updateStats(); renderTable();
  }
  document.getElementById('markUsedBtn').textContent =
    !isUsed ? '✕ Tandai Belum Digunakan' : '✓ Tandai Sudah Digunakan';
}

function renderTable(filter) {
  if (filter === undefined) filter = document.getElementById('searchInput').value;
  const tbody = document.getElementById('tableBody');
  const noResult = document.getElementById('noResult');
  tbody.innerHTML = '';
  let count = 0;
  const q = filter.toLowerCase();
  CODES.forEach((code, i) => {
    const num = i + 1;
    if (q && !String(num).includes(q) && !code.toLowerCase().includes(q)) return;
    count++;
    const used = usedSet.has(i);
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td class="num">#${String(num).padStart(3,'0')}</td>
      <td class="code-cell">${code}</td>
      <td><span class="status-badge ${used?'used':'available'}">${used?'Terpakai':'Tersedia'}</span></td>
      <td class="col-qr"><button class="qr-btn" onclick="openModal(${i},event)">QR / Redeem</button></td>`;
    tr.onclick = () => openModal(i);
    tbody.appendChild(tr);
  });
  noResult.style.display = count === 0 ? 'block' : 'none';
}

function filterCodes() { renderTable(document.getElementById('searchInput').value); }

function updateStats() {
  document.getElementById('usedCount').textContent  = usedSet.size;
  document.getElementById('availCount').textContent = CODES.length - usedSet.size;
}

function openModal(index, e) {
  if (e) e.stopPropagation();
  activeIndex = index;
  const code = CODES[index];
  const url  = REDEEM_BASE + code;
  document.getElementById('modalCode').textContent = code;
  document.getElementById('redeemLink').href = url;
  document.getElementById('markUsedBtn').textContent =
    usedSet.has(index) ? '✕ Tandai Belum Digunakan' : '✓ Tandai Sudah Digunakan';
  const container = document.getElementById('qr-container');
  container.innerHTML = '<div id="qr-inner"></div>';
  if (qrInstance) { try { qrInstance.clear(); } catch(err){} }
  qrInstance = new QRCode(document.getElementById('qr-inner'), {
    text: url, width: 200, height: 200,
    colorDark: '#000000', colorLight: '#ffffff',
    correctLevel: QRCode.CorrectLevel.M
  });
  document.getElementById('modalOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal(e) {
  if (e && e.target !== document.getElementById('modalOverlay')) return;
  document.getElementById('modalOverlay').classList.remove('open');
  document.body.style.overflow = '';
  activeIndex = null;
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
init();
</script>
